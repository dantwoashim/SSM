{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@assurance/core": [
        "packages/core/src/index.ts"
      ],
      "@assurance/core/*": [
        "packages/core/src/*"
      ],
      "@assurance/service": [
        "packages/service/src/index.ts"
      ],
      "@assurance/service/*": [
        "packages/service/src/*"
      ]
    }
  }
}
