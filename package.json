{
  "name": "identity-go-live-assurance",
  "private": true,
  "version": "0.1.0",
  "description": "Enterprise identity go-live assurance for SSO, SCIM, provisioning, and buyer-ready rollout reports.",
  "engines": {
    "node": ">=22 <26"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @assurance/web",
    "build": "npm run build:app",
    "build:app": "npm run build --workspaces --if-present",
    "package:source": "node scripts/build-source-bundle.mjs",
    "check:hygiene": "node scripts/check-release-hygiene.mjs",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "start": "npm run start --workspace @assurance/web",
    "prepare:local-prod": "npm run build && npm run seed",
    "smoke:docker": "node scripts/smoke-docker.mjs",
    "smoke:start": "node scripts/smoke-production-start.mjs",
    "smoke:source-bundle": "node scripts/smoke-source-bundle.mjs",
    "smoke:storage": "node --import tsx scripts/smoke-storage.mjs",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "playwright test",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run smoke:storage && npm run build && npm run smoke:start && npm run test:e2e && npm run check:hygiene",
    "worker": "npm run worker --workspace @assurance/worker",
    "seed": "npm run seed --workspace @assurance/web"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  }
}
